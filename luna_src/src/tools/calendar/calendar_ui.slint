export component CalendarUI inherits PageComponent {
    title: @tr("Calendar Widget");
    description: @tr("A calendar widget with monthly, daily and yearly views.");
    show-enable-read-only: false;
    show-enable-page-widgets-switch: false;

    // min-width: outer_layout.min-width;
    // min-height: outer_layout.min-height;
    // preferred-width: 1000px;
    // preferred-height: 1200px;

    padding-left: 10px;
    padding-right: 10px;
    padding-bottom: 20px;
    padding-top: 10px;


    outer_layout := HorizontalLayout {

        min-width: month_year_layout.min-width + day_view.min-width + upcoming_notes_layout.min-width;
        min-height: month_year_layout.min-height + day_view.min-height + upcoming_notes_layout.min-height;
        height: 100%;
        width: 100%;
        spacing: 5px;
        padding-bottom: 25px;

        month_year_layout := VerticalLayout {

            min-width: month_view.min-width + year_view.min-width;
            min-height: month_view.min-height + year_view.min-height;

            width: 30%;
            padding-bottom: 10px;
            

            month_view := MonthlyView {

                current_date_string: "Test Date";
                day_cell_dims: 20px;
            }

            year_view := YearlyView {

                current_year: 2026;
                day_cell_dims: 25px;
            }
        }
        
        day_view := DailyView {
            width: 45%;

            current_date: "Test date";

            hour_cell_width: 400px;
        }

        upcoming_notes_layout := VerticalLayout {
            padding-bottom: 14px;
            width: 25%;

            upcoming_view := UpcomingView {}
            notes_view := NotesView {}

        }





    }

}
